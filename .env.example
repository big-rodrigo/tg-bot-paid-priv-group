# Required: Telegram Bot API key from @BotFather
BOT_API_KEY=123456789:AABBccDDeeFFggHHiiJJkkLLmmNNoopp

# Database URL — sqlite (default) or postgres://user:pass@host/db for PostgreSQL
DATABASE_URL=sqlite:./data.db

# Telegram username of the admin (without @)
ADMIN_TELEGRAM_USERNAME=your_admin_username

# External payment API (leave empty to disable external payments)
PAYMENT_API_URL=https://payment.example.com/api/charge
PAYMENT_API_KEY=your_payment_api_key

# LivePix payment provider — set both to enable (takes priority over External API)
# Get these from your LivePix developer dashboard
# LIVEPIX_CLIENT_ID=your_livepix_client_id
# LIVEPIX_CLIENT_SECRET=your_livepix_client_secret
# Configure the donation page URL and minimum price in the admin web UI (Settings page) or set it as fallback with the vars:
# LIVEPIX_ACCOUNT_URL, LIVEPIX_PRICE_CENTS, LIVEPIX_CURRENCY

# Optional: enables Telegram native payments if set
# TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# Admin web interface
WEB_INTERFACE_PORT=3000
WEB_INTERFACE_SECRET=changeme_use_a_strong_secret_here

# Public base URL for this server — set to your ngrok tunnel URL when testing webhooks locally.
# The bot will log the full webhook URL on startup for easy copy-pasting into the LivePix dashboard.
# WEBHOOK_BASE_URL=https://abc123.ngrok-free.app

# Logging (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=tg_bot=debug,tower_http=info
